generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  COMPANY
  ADMIN
}

enum CourseType {
  DIPLOMA
  SHORT_COURSE
  CERTIFICATION
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  REFUNDED
}

enum PrototypeStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum RecommendationType {
  LEARNER
  BUILDER
}

enum SandboxStatus {
  STARTING
  RUNNING
  PAUSED
  STOPPED
  ERROR
}

model User {
  id              String            @id @default(cuid())
  clerkId         String            @unique
  email           String            @unique
  name            String
  avatarUrl       String?
  role            Role              @default(STUDENT)
  careerGoal      String?
  bio             String?
  company         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  enrollments     Enrollment[]
  certificates    Certificate[]
  prototypes      Prototype[]
  recommendations Recommendation[]
  activityEvents  ActivityEvent[]
  payments        Payment[]
}

model Course {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  description     String
  longDescription String?
  type            CourseType
  level           CourseLevel  @default(BEGINNER)
  price           Float
  duration        Int
  tags            String[]
  published       Boolean      @default(false)
  thumbnailUrl    String?
  videoPreviewUrl String?
  instructorName  String?
  instructorBio   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  modules         Module[]
  enrollments     Enrollment[]
  certificates    Certificate[]
  products        Product[]
}

model Module {
  id       String   @id @default(cuid())
  courseId  String
  title    String
  order    Int
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

model Lesson {
  id       String  @id @default(cuid())
  moduleId String
  title    String
  content  String  @db.Text
  videoUrl String?
  duration Int?
  order    Int
  hasQuiz  Boolean @default(false)
  quizData Json?
  module   Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId     String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0)
  score       Float?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])
  course      Course           @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Certificate {
  id              String   @id @default(cuid())
  userId          String
  courseId         String
  uniqueId        String   @unique @default(cuid())
  issuedAt        DateTime @default(now())
  templateId      String   @default("default")
  verificationUrl String?
  pdfUrl          String?
  user            User     @relation(fields: [userId], references: [id])
  course          Course   @relation(fields: [courseId], references: [id])
}

model Prototype {
  id          String          @id @default(cuid())
  userId      String
  title       String
  description String?
  techStack   String[]
  sandboxId   String?
  status      PrototypeStatus @default(ACTIVE)
  artifacts   Json?
  repoUrl     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id])
  sandbox     Sandbox?
}

model Sandbox {
  id          String        @id @default(cuid())
  prototypeId String        @unique
  containerId String?
  status      SandboxStatus @default(STARTING)
  image       String
  port        Int?
  lastActive  DateTime      @default(now())
  createdAt   DateTime      @default(now())
  prototype   Prototype     @relation(fields: [prototypeId], references: [id])
}

model Recommendation {
  id        String             @id @default(cuid())
  userId    String
  type      RecommendationType
  payload   Json
  context   Json
  feedback  Int?
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Product {
  id              String @id @default(cuid())
  courseId         String
  stripeProductId String
  stripePriceId   String
  amount          Float
  currency        String @default("USD")
  course          Course @relation(fields: [courseId], references: [id])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  stripePaymentId String   @unique
  amount          Float
  currency        String
  status          String
  metadata        Json?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}
